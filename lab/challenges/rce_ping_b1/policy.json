{
  "id": "rce_ping_b1",
  "title": "命令注入 · B1（空格被拦）",
  "allowedCommands": ["ping", "ls", "grep", "cat"],
  "safeFiles": ["hosts", "app.log", "passwd.mock"],
  "allowLsOptionLa": true,
  "grepAllowRegex": false,
  "grepKeywordPattern": "^[a-zA-Z0-9._-]+$",
  "hostPattern": "^[a-zA-Z0-9.-]+$",
  "pathPattern": "^[a-zA-Z0-9._/-]+$",
  "weakenPathTraversal": false,
  "transformRemoveSpaces": true,
  "transformDecodeUrl": false
}
